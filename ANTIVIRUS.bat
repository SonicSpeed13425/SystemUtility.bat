:UserInputPart
set userinput=
set /p userinput="%ESC%[38;2;0;255;255mв•ҡв•җ%USERNAME%>>"

if /i "%userinput%"=="help" goto Help
if /i "%userinput%"=="malwareremover" goto MalwareRemover
if /i "%userinput%"=="scansfc" goto scansfc
if /i "%userinput%"=="clear" goto Home
if /i "%userinput%"=="cls" goto Home
if /i "%userinput%"=="blockstun" goto blockstun
if /i "%userinput%"=="quit" exit
if /i "%userinput%"=="unblockstun" goto unblockstun
if /i "%userinput%"=="exit" exit
if /i "%userinput%"=="viewfirewallrules" goto viewfirewallrules

:Invalid
echo.
echo в•”в•җ[ERROR] Invalid Command.
echo в• в•җ"%userinput%" is not recognised as a command/action
goto UserInputPart

:Help
echo.
echo в•”в•җHelp - Shows a list of available commands
echo в• в•җmalwareremover - Preform a scan that removes infected system files and viruses.
echo в• в•җscansfc - repairs corrupted or missing files using cached copies stored on your PC.
echo в• в•җclear/cls - clears everything on screen and restarts the title.
echo в• в•җblockstun - blocks stun protocols that hackers may use to get your IP address.
echo в• в•җquit/exit - exit/quit
echo в• в•җunblockstun - unblock stun protocols [NOT RECOMMENDED]
echo в• в•җviewfirewallrules - open wf.msc/wd with advanced security
goto UserInputPart

:MalwareRemover
echo.
echo в•”в•җ[INFO] This will open the official mrt tool for windows.
echo в• в•җLaunching.
start mrt
goto UserInputPart

:scansfc
echo.
echo в•”в•җ[INFO] Admin-level command.
echo в• в•җScanning...
net session >nul 2>&1
if %errorlevel% neq 0 (
echo в• в•җ[ERROR] Not admin.
goto UserInputPart
) else (
echo в•ҡв•җThis may take a while, closing the window will leave partially repaired files.
echo.
sfc /scannow >nul
if %errorlevel% equ 0 (
echo в•”в•җSuccess!
) else if %errorlevel% equ 1 (
    echo в•”в•җ[ERROR] Failed to run.
)
goto UserInputPart
)

:blockstun
echo.
set "found="
echo в•”в•җ[INFO] Admin-level command.
net session >nul 2>&1
if %errorlevel% neq 0 (
echo в• в•җ[ERROR] Not admin.
goto UserInputPart
) else (
echo в• в•җCreating wf.msc rule.
for /f "delims=" %%A in ('netsh advfirewall firewall show rule name^="stun block" ^| find "stun block"') do set found=1

if defined found (
    echo в• в•җStun protocols are already blocked!
) else (
netsh advfirewall firewall add rule name="stun block" dir=out action=block protocol=UDP remoteport=3478 >nul
if %errorlevel% equ 0 (
echo в• в•җSuccess!
) else if %errorlevel% equ 2 (
echo в• в•җ[ERROR] System-level failure occured.
) else (
echo в• в•җ[ERROR] Not admin.
)
)
goto UserInputPart
)

:unblockstun
echo.
echo в•”в•җ[INFO] Admin-level command.
net session >nul 2>&1
if %errorlevel% neq 0 (
echo в• в•җ[ERROR] Not Admin!
goto UserInputPart
) else (
echo в• в•җDeleting stun protection rules.
netsh advfirewall firewall delete rule name="stun block" dir=out >nul
if %errorlevel% equ 0 (
echo в• в•җSuccess!
) else if %errorlevel% equ 2 (
echo в• в•җ[ERROR] System-level failure occured.
) else (
echo в• в•җ[ERROR] Not admin.
)
goto UserInputPart
)

:viewfirewallrules
echo.
echo в•”в•җ[INFO] Starting wf.msc
echo в• в•җ[INFO] Stunblock can be found here if you blocked stun.
echo в• в•җLaunching
start wf.msc
goto UserInputPart
